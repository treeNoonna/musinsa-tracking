{
  "name": "musinsa-price-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm run dev:local",
    "dev:frontend": "next dev --hostname 127.0.0.1 --port 3000",
    "dev:backend": "cd backend/scraper-worker && python3.11 -m uvicorn app:app --host 127.0.0.1 --port 8000",
    "dev:local": "sh -c 'if lsof -tiTCP:8000 -sTCP:LISTEN >/dev/null 2>&1; then echo \"backend already running on 8000\"; else npm run dev:backend & fi; npm run dev:frontend'",
    "build": "next build",
    "start": "next start",
    "lint": "next lint"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.8",
    "next": "^15.2.8",
    "react": "^19.0.1",
    "react-dom": "^19.0.1"
  },
  "devDependencies": {
    "@types/node": "22.13.10",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "eslint": "9.22.0",
    "eslint-config-next": "^15.2.8",
    "typescript": "5.8.2"
  }
}
